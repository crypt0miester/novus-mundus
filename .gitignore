# Icon source generations — 1024px Krea raws. Re-export from these via
# images/scripts/export-icons-to-app.sh; never shipped to the client.
images/icons/raw/

# Bonsai-Image-4B local checkout — cloned by images/scripts/bonsai-install.sh.
# Contains a Python venv and multi-GB MLX model weights; never committed.
# Re-clone on any new machine via bonsai-install.sh.
images/bonsai/

# Hero silhouette source generations — 1024px Bonsai raws. Re-export from
# these via images/scripts/export-heroes-to-app.sh; never shipped to client.
images/heroes/raw/

# Bonsai-baked portrait layers (halos, frames, city sigils, ascension marks).
# Re-export raws to the app via images/scripts/export-<type>-to-app.sh.
images/halos/raw/
images/frames/raw/
images/sigils/raw/
images/marks/raw/
images/banners/raw/
images/castles/raw/
images/dungeons/raw/
images/events/raw/
images/empty-states/raw/
images/readme/raw/
