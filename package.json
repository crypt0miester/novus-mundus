{
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "sdks/novus-mundus-ts"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "typecheck": "turbo typecheck",
    "validator": "./sdks/novus-mundus-ts/scripts/start-validator.sh --reset",
    "validator:stop": "./sdks/novus-mundus-ts/scripts/stop-validator.sh",
    "setup": "cd sdks/novus-mundus-ts && bun run cli/cli.ts init all --env localnet",
    "setup:status": "cd sdks/novus-mundus-ts && bun run cli/cli.ts status --env localnet",
    "cli": "cd sdks/novus-mundus-ts && bun run cli/cli.ts"
  },
  "dependencies": {
    "@project-serum/anchor": "^0.25.0"
  },
  "devDependencies": {
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "ts-mocha": "^10.0.0",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "typescript": "^4.3.5",
    "prettier": "^2.6.2",
    "turbo": "^2"
  }
}
