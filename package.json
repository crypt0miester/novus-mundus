{
  "private": true,
  "packageManager": "bun@1.2.10",
  "workspaces": [
    "apps/*",
    "sdks/*"
  ],
  "scripts": {
    "preinstall": "for d in core/base core/react ui/react-ui wallets/wallets wallet-standard/base; do (cd ../../wallet-adapter-v3/packages/$d && bun link) 2>/dev/null || true; done",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "typecheck": "turbo typecheck",
    "novus": "cd sdks/novus-mundus-ts && bun run cli/cli.ts"
  },
  "overrides": {
    "@solana/web3.js": "3.0.0-rc.1"
  },
  "devDependencies": {
    "chai": "4.3.4",
    "mocha": "9.0.3",
    "ts-mocha": "10.0.0",
    "@types/chai": "4.3.0",
    "@types/mocha": "9.0.0",
    "typescript": "4.3.5",
    "prettier": "2.6.2",
    "turbo": "2.9.2"
  }
}
