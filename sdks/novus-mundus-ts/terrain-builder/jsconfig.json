{
  "compilerOptions": {
    "checkJs": true,
    "strict": false,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM"],
    "noEmit": true,
    "skipLibCheck": true,
    "maxNodeModuleJsDepth": 0,
    "paths": {
      "three": ["./node_modules/three/src/Three.d.ts"],
      "three/addons/*": ["./node_modules/three/examples/jsm/*"]
    },
    "baseUrl": "."
  },
  "include": [
    "src/**/*.js",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "data"
  ]
}
