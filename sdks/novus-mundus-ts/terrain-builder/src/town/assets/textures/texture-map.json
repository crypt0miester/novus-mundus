{
  "_meta": {
    "description": "Texture asset mapping for terrain-builder town renderer",
    "source": "ambientcg.com (CC0) + polyhaven.com (CC0)",
    "resolution": "1K",
    "file_convention": "{pack-name}/{pack-name}-{map-type}.jpg  (exr for HDRIs)",
    "map_types": {
      "color": "map (diffuse albedo)",
      "normal": "normalMap (OpenGL tangent-space)",
      "roughness": "roughnessMap",
      "ao": "aoMap (ambient occlusion)",
      "displacement": "displacementMap (height)",
      "metalness": "metalnessMap (where present)",
      "opacity": "alphaMap (where present)"
    }
  },

